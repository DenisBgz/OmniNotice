# Публичный путь приложения при сборке (Vite). Для корня сайта: /
# VITE_BASE_URL=/
# В GitLab CI содержимое переменной ENV_FILE копируется в .env.production перед docker build.

# Synora API (без слэша в конце)
VITE_SYNORA_BASE_URL=https://api.synora.example.ru

# Project-ID (нужен как заголовок `Project-ID` при вызове Synora)
# Значение выдаёт бекенд/инфра (из настроек проекта в Synora)
VITE_SYNORA_PROJECT_ID=example

# UserCenter API (авторизация)
VITE_USERCENTER_BASE_URL=https://api.users.skroy.ru
VITE_USERCENTER_PROJECT_ID=example

# Топик общего конвейера подготовки писем (по умолчанию mail-send → MailSend)
VITE_SYNORA_EVENT_TOPIC=mail-send

# Имя шаблона в Synora (опционально, если шаблон задаётся в событии)
# VITE_SYNORA_MAIL_TEMPLATE=omninotice_mailing_v1

#Промпт ID для Oracle
VITE_PROMT_ID=example

#Промт: Ты — senior direct-response copywriter. Пиши продающие рассылки, которые повышают открываемость, кликабельность и конверсию.
#Перед написанием определи главную боль аудитории, ключевую выгоду продукта и мотив покупки.
#Затем создай текст рассылки с сильным заголовком, эмоциональным входом, выгодным оффером и понятным CTA.
#Пиши, конкретно, без штампов.
